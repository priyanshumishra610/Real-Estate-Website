# ==========================================
# BuildEstate Backend Environment Variables
# ==========================================
# Copy this file to .env (or .env.local) and fill in your actual values
# For security, never commit .env files to version control


# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=4000
NODE_ENV=development
BACKEND_URL="http://localhost:4000"


# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# MongoDB Connection String
# Get this from MongoDB Atlas (https://cloud.mongodb.com) or use local MongoDB
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGO_URI="mongodb+srv://your_username:your_password@your_cluster.mongodb.net/buildestate?retryWrites=true&w=majority"


# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
# Generate a strong random string for JWT (use: openssl rand -base64 32)
JWT_SECRET="your_super_secure_jwt_secret_here_make_it_long_and_random"


# ===========================================
# EMAIL CONFIGURATION (Required for user notifications)
# ===========================================
# Option 1: Brevo (SendinBlue) SMTP (Recommended - Free tier available)
# Sign up at https://www.brevo.com/
SMTP_USER="your_brevo_smtp_login"
SMTP_PASS="your_brevo_smtp_password"
EMAIL_USER="your_sender_email@domain.com"
BREVO_API_KEY="your_brevo_api_key"

# Option 2: Gmail SMTP (Alternative)
# Enable 2FA and generate App Password at https://myaccount.google.com/apppasswords
# SMTP_USER="your_email@gmail.com"
# SMTP_PASS="your_gmail_app_password"
# EMAIL="your_email@gmail.com"

# Admin Account Credentials (Change these!)
ADMIN_EMAIL="admin@propvista.com"
ADMIN_PASSWORD="change_this_secure_password"


# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# URL where your frontend is deployed
# Local: http://localhost:5173
# Vercel: https://your-project.vercel.app
WEBSITE_URL=""
# IMPORTANT: Set this to your production frontend URL (e.g. https://yourdomain.vercel.app)
# Email verification and password reset links are built from this value.
# Leaving it empty or pointing to localhost will break those emails in production.

# CORS allowlist (used by backend/server.js)
# Primary frontend URL
FRONTEND_URL="http://localhost:5173"
# Primary admin URL
ADMIN_URL="http://localhost:5174"
# Optional comma-separated local origins
LOCAL_URLS="http://localhost:5173,http://localhost:5174,http://localhost:4000"
# Optional extra origins (comma-separated)
EXTRA_ALLOWED_ORIGINS=""


# ===========================================
# IMAGE STORAGE (Optional but Recommended)
# ===========================================
# ImageKit provides free tier for image optimization and CDN
# Sign up at https://imagekit.io for free account (10GB free)
IMAGEKIT_PUBLIC_KEY="public_your_imagekit_public_key"
IMAGEKIT_PRIVATE_KEY="private_your_imagekit_private_key"
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_imagekit_id"


# ===========================================
# AI SERVICES (Optional - for AI Property Hub)
# ===========================================
# These are optional - only needed if you want AI property search features
# Users can still provide their own API keys via frontend

# Firecrawl for web scraping property data
# Get API key from https://www.firecrawl.dev/ (Free tier: 500 pages/month)
FIRECRAWL_API_KEY="fc-your_firecrawl_api_key_here"

# GitHub Models for AI (Free tier available)
# Generate Personal Access Token at https://github.com/settings/tokens
# No additional permissions needed for GitHub Models
GITHUB_MODELS_API_KEY="github_pat_your_github_personal_access_token"


# ===========================================
# OPTIONAL CONFIGURATIONS
# ===========================================
# Rate limiting (requests per hour)
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000

# Session settings
SESSION_TIMEOUT_MINUTES=60

# File upload limits
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_PROPERTY=10